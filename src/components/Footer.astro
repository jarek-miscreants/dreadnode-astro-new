---
// Footer — ported from dreadnode.io, styled with design tokens.
import CanvasAnimation from "./CanvasAnimation.astro";
import Button from "./Button.astro";

type FooterLink = { label: string; href: string; external?: boolean };
type FooterColumn = { heading: string; links: FooterLink[] };

const columns: FooterColumn[] = [
  {
    heading: "Platform",
    links: [
      { label: "Get Started", href: "https://app.dreadnode.io/?mode=register", external: true },
      { label: "Pricing", href: "/pricing" },
      { label: "Docs", href: "https://docs.dreadnode.io", external: true },
    ],
  },
  {
    heading: "Research",
    links: [
      { label: "Blog", href: "/research?filter=blog" },
      { label: "Papers", href: "/research?filter=papers" },
      { label: "GitHub", href: "https://github.com/dreadnode", external: true },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About", href: "/company/about" },
      { label: "Newsroom", href: "/company/newsroom" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    heading: "Connect",
    links: [
      { label: "LinkedIn", href: "https://www.linkedin.com/company/dreadnode/", external: true },
      { label: "X", href: "https://x.com/dreadnode", external: true },
      { label: "YouTube", href: "https://www.youtube.com/@dreadnode", external: true },
      { label: "Contact Us", href: "/contact" },
    ],
  },
];

const legalLinks: FooterLink[] = [
  { label: "Privacy Policy", href: "https://app.dreadnode.io/privacy", external: true },
  { label: "Terms & Conditions", href: "https://app.dreadnode.io/terms", external: true },
];

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden" style="background-color: #e6532d;" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Site footer</h2>



  <div class="relative z-10 mx-auto w-full max-w-[90rem] px-4 py-16 md:px-12 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <!-- Brand + newsletter -->
      <div class="md:col-span-5">
        <a href="/" aria-label="Dreadnode home" class="inline-flex items-center">
          <img src="/images/logo-dreadnode.svg" alt="Dreadnode" class="h-auto w-40" />
        </a>
        <p class="mt-4 max-w-xs font-mono text-body-xsm uppercase tracking-wider text-muted">
          AI infrastructure for the security stack.
        </p>

        <form class="mt-8 max-w-sm" aria-label="Newsletter signup">
          <label for="footer-email" class="block font-mono text-body-xsm uppercase tracking-wider text-light">
            Subscribe
          </label>
          <div class="mt-3 flex flex-col gap-2 sm:flex-row">
            <input
              id="footer-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="Email address"
              class="flex-1 border border-light-faded bg-transparent px-3 py-2 text-body-sm text-white placeholder:text-white/60 focus:border-white focus:outline-none"
            />
            <Button label="Sign up" type="submit" variant="primary" />
          </div>
          <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2">
            <label class="sr-only" for="footer-first-name">First name</label>
            <input
              id="footer-first-name"
              name="first-name"
              type="text"
              autocomplete="given-name"
              placeholder="First name"
              class="border border-light-faded bg-transparent px-3 py-2 text-body-sm text-white placeholder:text-white/60 focus:border-white focus:outline-none"
            />
            <label class="sr-only" for="footer-last-name">Last name</label>
            <input
              id="footer-last-name"
              name="last-name"
              type="text"
              autocomplete="family-name"
              placeholder="Last name"
              class="border border-light-faded bg-transparent px-3 py-2 text-body-sm text-white placeholder:text-white/60 focus:border-white focus:outline-none"
            />
          </div>
        </form>
      </div>

      <!-- Columns -->
      <nav class="grid grid-cols-2 gap-8 md:col-span-7 md:grid-cols-4" aria-label="Footer">
        {columns.map((col) => (
          <div>
            <h3 class="font-mono text-body-xsm uppercase tracking-wider text-light">{col.heading}</h3>
            <ul class="mt-4 space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                    class="text-body-sm font-mono uppercase tracking-wider text-muted transition-colors hover:text-orange focus:outline-none focus-visible:text-orange"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <!-- Legal -->
    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-light-faded pt-6 md:flex-row md:items-center">
      <p class="font-mono text-body-xsm uppercase tracking-wider text-muted">
        &copy; {year} Dreadnode. All rights reserved.
      </p>
      <ul class="flex flex-wrap gap-6">
        {legalLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="font-mono text-body-xsm uppercase tracking-wider text-muted transition-colors hover:text-orange focus:outline-none focus-visible:text-orange"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
