---
interface Props {
  href: string;
  label: string;
  target?: string;
  rel?: string;
  class?: string;
}

const { href, label, target, rel, class: className } = Astro.props;
---

<div class:list={["relative", className]}>
  <slot />
  <a
    href={href}
    target={target}
    rel={rel}
    class="absolute inset-0 z-[1] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current focus-visible:rounded-[inherit]"
    aria-label={label}
  >
    <span class="sr-only">{label}</span>
  </a>
</div>
