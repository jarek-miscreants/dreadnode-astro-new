---
import { getCollection } from "astro:content";
import LayoutMain from "../../layouts/LayoutMain.astro";
import SectionMain from "../../components/SectionMain.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import Grid from "../../components/Grid.astro";

const team = (await getCollection("team", ({ data }) => !data.draft)).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<LayoutMain>
    <SectionMain
        id="about"
        paddingTop="lg"
        paddingBottom="sm"
        contentClass="relative"
    >
        <div class="container-large">
            <Grid
                mobile={1}
                mobileLandscape={1}
                tablet={1}
                desktop={5}
                gap="gap-6"
            >
                <div class="col-span-1">
                    <Eyebrow label="Why we exist" class="text-orange mb-4" />
                </div>

                <div class="col-span-4">
                    <h1 class="h2">
                        We exist to make AI-native security a reality
                    </h1>
                    <p class="h4 mt-6">
                        Not just AI for security. The infrastructure the
                        security industry needs to operationalize AI at scale.
                    </p>
                </div>
            </Grid>
        </div>
    </SectionMain>
    <SectionMain
        id="our-story"
        paddingTop="sm"
        paddingBottom="sm"
        contentClass="bg-elevated section-border-bottom section-border-top relative"
    >
        <div class="container-large">
            <Grid
                mobile={1}
                mobileLandscape={1}
                tablet={1}
                desktop={5}
                gap="gap-6"
            >
                <div class="col-span-1">
                    <Eyebrow label="Our Story" class="text-orange mb-4" />
                </div>
                <div class="col-span-4">
                    <h2 class="h3">
                        Built by (and for) offensive security operators
                    </h2>
                    <p
                        class="text-body-md lg:text-body-lg text-muted mt-6"
                    >
                        Dreadnode was founded with the mission to prove AI can
                        perform offensive security operations. That thesis has
                        been validated across use cases. Offense was the proving
                        ground, and we now recognize that the opportunity is
                        even bigger: AI is going to change the entire security
                        stack. While we continue to prioritize offensive
                        security and AI red teaming capabilities, we’ve built
                        what’s required to achieve AI-native security.
                    </p>
                </div>
            </Grid>
        </div>
    </SectionMain>

    {/* ============================== TEAM ============================== */}
    <SectionMain
        id="team"
        paddingTop="md"
        paddingBottom="lg"
        contentClass="relative"
    >
        <div class="container-large">
            <Grid
                mobile={1}
                mobileLandscape={2}
                tablet={3}
                desktop={4}
                gap="gap-4"
            >
                <div class="flex flex-col justify-center col-span-1">
                    <Eyebrow label="Team" class="text-orange mb-4" />
                    <h2 class="h3">Meet the crew</h2>
                    <p class="text-body-md text-muted mt-4 max-w-[36ch]">
                        Uniquely qualified to solve the hardest problems in
                        offensive AI.
                    </p>
                </div>

                {team.map((member) => (
                    <article class="team-card border border-muted-dark rounded-sm overflow-hidden bg-elevated flex flex-col">
                        <img
                            src={member.data.image}
                            alt={`${member.data.name} — ${member.data.role}`}
                            loading="lazy"
                            decoding="async"
                            width="400"
                            height="400"
                            class="w-full aspect-square object-cover"
                        />
                        <div class="flex items-start justify-between gap-3 p-4">
                            <div class="flex flex-col gap-1 min-w-0">
                                <span class="font-mono text-body-sm uppercase tracking-wider text-light truncate">
                                    {member.data.name}
                                </span>
                                <span class="font-mono text-body-xsm uppercase tracking-wider text-muted">
                                    {member.data.role}
                                </span>
                            </div>
                            {member.data.linkedin && (
                                <a
                                    href={member.data.linkedin}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={`${member.data.name} on LinkedIn`}
                                    class="text-muted hover:text-light transition-colors shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 20 20"
                                        fill="currentColor"
                                        class="w-5 h-5"
                                        aria-hidden="true"
                                    >
                                        <path d="M17.0409 17.0413H14.0776V12.4004C14.0776 11.2937 14.0578 9.86912 12.5363 9.86912C10.9929 9.86912 10.7567 11.0749 10.7567 12.3199V17.041H7.79336V7.49741H10.6382V8.80165H10.678C10.9627 8.31485 11.3741 7.91439 11.8684 7.64291C12.3627 7.37143 12.9214 7.23911 13.4849 7.26003C16.4884 7.26003 17.0422 9.23568 17.0422 11.8059L17.0409 17.0413ZM4.44969 6.19287C4.10957 6.19293 3.77706 6.09213 3.49422 5.90321C3.21139 5.71429 2.99094 5.44574 2.86073 5.13153C2.73051 4.81731 2.69638 4.47153 2.76268 4.13792C2.82897 3.80431 2.99271 3.49785 3.23317 3.2573C3.47363 3.01675 3.78002 2.8529 4.11359 2.78649C4.44716 2.72007 4.79293 2.75406 5.10719 2.88417C5.42144 3.01428 5.69006 3.23465 5.87907 3.51743C6.06808 3.80021 6.16901 4.13268 6.16907 4.47282C6.16911 4.69866 6.12466 4.92229 6.03827 5.13095C5.95189 5.33962 5.82527 5.52922 5.66561 5.68895C5.50595 5.84867 5.31638 5.97538 5.10775 6.06184C4.89913 6.1483 4.67552 6.19282 4.44969 6.19287ZM5.93137 17.0413H2.96491V7.49741H5.93137V17.0413ZM18.5183 0.00136263H1.47583C1.08901 -0.00300274 0.716265 0.146386 0.439533 0.416702C0.162802 0.687018 0.00472088 1.05614 0 1.44297V18.5567C0.00455931 18.9438 0.162547 19.3131 0.43927 19.5837C0.715992 19.8543 1.08882 20.004 1.47583 19.9999H18.5183C18.9061 20.0047 19.28 19.8555 19.5578 19.5849C19.8356 19.3143 19.9946 18.9445 20 18.5567V1.44174C19.9945 1.05414 19.8353 0.684596 19.5575 0.414287C19.2797 0.143978 18.9059 -0.00498453 18.5183 0.000127351" />
                                    </svg>
                                </a>
                            )}
                        </div>
                    </article>
                ))}
            </Grid>
        </div>
    </SectionMain>
</LayoutMain>
